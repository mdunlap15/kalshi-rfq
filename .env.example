# ProphetX Parlay SP credentials
PX_BASE_URL=https://api-ss-sandbox.betprophet.co
PX_ACCESS_KEY=your_access_key
PX_SECRET_KEY=your_secret_key

# The Odds API
ODDS_API_KEY=your_odds_api_key

# Service config
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Pricing params
DEFAULT_VIG=0.06
MAX_RISK_PER_PARLAY=10
MAX_LEGS=8
STALE_PRICE_MINUTES=15
ODDS_CACHE_TTL_MINUTES=30

# Supported sports (comma-separated, must match The Odds API sport keys)
SUPPORTED_SPORTS=basketball_nba,baseball_mlb,icehockey_nhl
